{
  "expo": {
    "name": "galarieslafayette",
    "slug": "galarieslafayette",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parthiban123.galarieslafayette"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "myapp"
            },
            {
              "scheme": "https",
              "host": "parthiban-surendran.github.io",
              "pathprefix":"/home"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "package": "com.parthiban123.galarieslafayette"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      "expo-font"
    ],
    "scheme":"myapp",
    "extra": {
      "eas": {
        "projectId": "000c5d1e-f524-432e-8de3-61e08373e940"
      }
    },
    "owner": "parthiban123"
  }
}
